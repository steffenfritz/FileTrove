#
# Binaries for programs and plugins
/ftrove
/admftrove
cmd/admftrove/admftrove
ftrove_*
admftrove_*
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories
vendor/

# Exclude logs
cmd/ftrove/logs/

# Go workspace file
go.work
cmd/ftrove/db
.idea

# Databases
nsrl_sha1_uniq_*
nsrl.db
db/

# NSRL build artifacts
tmp/nsrl/

# Distribution bundles
build/

# Package build output
dist/

# Misc
.DS_Store
.claude

# Taskfile state
.task/
cmd/ftrove/.yara_env
testdata/noaccess.rtf
resources
